# ── Supabase ──────────────────────────────────────────────
# Project URL and keys from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────
# Public base URL (used for metadata). On Vercel this is your deployment URL.
NEXT_PUBLIC_APP_URL=https://sip-spp.vercel.app

# Optional: allows re-running POST /api/setup/init after an admin exists.
# Leave unset in production.
# SETUP_SECRET=

# ── Rate limiting (optional, fail-open if unset) ──────────
# Upstash Redis — protects the login endpoint from brute force.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
